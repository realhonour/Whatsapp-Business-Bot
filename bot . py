    from flask import Flask, request
from twilio.twiml.messaging_response import MessagingResponse
app = Flask(__name__)

@app.route("/whatsapp", methods=['POST'])
def whatsapp_reply():
    incoming_msg = request.values.get('Body', '').lower()
    resp = MessagingResponse()
    msg = resp.message()

    if "price" in incoming_msg:
        msg.body("Our rooms start from ₦25,000/night. Would you like to book?")
    elif "book" in incoming_msg:
        msg.body("Great! Please send your check-in date and name.")
    else:
        msg.body("Hi! Reply 1 for Prices, 2 for Booking, 3 for Location, 4 for Agent")
    
    return str(resp)

if __name__ == "__main__":
    app.run()